# CryoGuard Backend Environment Variables
# Copy this file to .env and fill in your values

# Spring Profile
SPRING_PROFILES_ACTIVE=dev

# Server Configuration
SERVER_PORT=8080

# JWT Configuration
# IMPORTANT: Change this secret in production! Use a minimum of 256-bit key.
JWT_SECRET=change-me-in-production-min-256-bits-long-secret-key-here
JWT_EXPIRATION_MS=86400000

# H2 Database (for development)
# Note: In Docker, database is persisted to /opt/h2-data
SPRING_DATASOURCE_URL=jdbc:h2:mem:cryoguard
SPRING_DATASOURCE_DRIVERCLASSNAME=org.h2.Driver
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# JPA/Hibernate
SPRING_JPA_HIBERNATE_DDL_AUTO=create-drop
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.H2Dialect

# H2 Console (disable in production)
SPRING_H2_CONSOLE_ENABLED=true
SPRING_H2_CONSOLE_PATH=/h2-console